<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

	<CheckButton name="RESTEDOptionsCheckButtonTemplate" inherits="InterfaceOptionsCheckButtonTemplate" virtual="true">
		<Scripts>
			<OnEnter>
				GameTooltip:SetOwner(self, "ANCHOR_LEFT");
				GameTooltip:SetText(self.tooltip);
			</OnEnter>
			<OnLeave>GameTooltip:Hide();</OnLeave>
		</Scripts>
	</CheckButton>

	<Frame name="RestedOptionsFrame">
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parent_Title" inherits="GameFontNormalLarge">
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset><AbsDimension x="16" y="-16"/></Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="$parent_NagHeader" inherits="GameFontNormal" text="Nag Report:">
					<Anchors>
						<Anchor point="TOPLEFT" relativeTo="$parent_Title" relativePoint="BOTTOMLEFT" x="16" y="-10"/>
					</Anchors>
				</FontString>
				<FontString name="$parent_AutoShowHeader" inherits="GameFontNormal" text="Auto show for:">
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parent_NagHeader" relativePoint="RIGHT" x="10" y="-16"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<CheckButton name="$parent_ShowNagReport" inherits="RESTEDOptionsCheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent_NagHeader" relativePoint="BOTTOMLEFT">
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>self.tooltip = "Enable auto display of Nag Report";</OnLoad>
					<OnShow>Rested.OptionsPanel_CheckButton_OnLoad(self,"nagEnabled","Enable");</OnShow>
					<OnClick>Rested.OptionsPanel_CheckButton_OnClick(self,"nagEnabled")</OnClick>
				</Scripts>
			</CheckButton>
			<EditBox name="$parent_NagTimeOut" inherits="InputBoxTemplate" autoFocus="false">
				<Size x="100" y="16"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parent_AutoShowHeader" relativePoint="RIGHT" x="10" y="-16" />
				</Anchors>
				<Scripts>
					<!-- <OnShow>INEED.OptionsPanel_EditBox_OnLoad( self, "emote" )</OnShow>
					<OnTextChanged>INEED.OptionsPanel_EditBox_TextChanged( self, "emote" )</OnTextChanged> -->
				</Scripts>
			</EditBox>
			<CheckButton name="$parent_IncludeLeveling" inherits="RESTEDOptionsCheckButtonTemplate">
			</CheckButton>

		</Frames>
		<Scripts>
			<OnLoad>
				Rested.OptionsPanel_OnLoad(self)
			</OnLoad>
		</Scripts>
	</Frame>
</Ui>
